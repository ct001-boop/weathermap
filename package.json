{
  "name": "skiweather-snow-forecast-map",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "patch:snowfall": "node scripts/patch-snowfall.cjs",
    "patch:horizon": "node scripts/patch-chart-horizon.cjs",
    "patch:all": "npm run patch:snowfall && npm run patch:horizon",
    "dev": "npm run patch:all && vite --host 0.0.0.0",
    "build": "npm run patch:all && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-basic-ssl": "latest",
    "axios": "latest",
    "chart.js": "latest",
    "leaflet": "latest",
    "nouislider": "latest",
    "vite": "latest"
  },
  "devDependencies": {}
}
